# WhatsApp Provider Configuration
# Supported providers: wwebjs, whaileys
WHATSAPP_PROVIDER=wwebjs
PORT=8080
# Logging (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
WHAILEYS_LOG_LEVEL=error

# Chrome/Puppeteer Configuration
CHROME_BIN=
CHROME_WS=
CHROME_ARGS=--no-sandbox --disable-setuid-sandbox

# Database
DB_HOST=localhost
DB_DIALECT=mysql
DB_PORT=3306
DB_NAME=whaticket
DB_USER=whaticket
DB_PASS=whaticket

# Sequelize connection pool (opcional - valores padrão já cobrem ~1000 atendimentos/semana)
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Secrets
JWT_SECRET=mysecret
JWT_REFRESH_SECRET=myanothersecret

# Backend URL
BACKEND_URL=http://localhost:8080

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Proxy
PROXY_PORT=8080

# Redis (usado para sessão de chaves do WhatsApp e cache de leitura de
# settings/filas/opções de chatbot - ver src/libs/redisStore.ts)
# Opção 1 (padrão deste projeto): host/porta/senha separados
IO_REDIS_SERVER=127.0.0.1
IO_REDIS_PASSWORD=
IO_REDIS_PORT=6379
IO_REDIS_DB_SESSION=2
# Opção 2: string de conexão completa, tem prioridade sobre as variáveis acima
# se estiver definida (ex: redis://:senha@host:6379/0)
# REDIS_URL=
